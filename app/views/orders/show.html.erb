<% content_for :title, "Order #{@order.number}" %>

<div class="mb-6">
  <%= link_to "← Back to orders", orders_path, class: "text-sm text-slate-500 hover:text-slate-800" %>
</div>

<div class="flex items-start justify-between gap-6 mb-6">
  <div>
    <h1 class="text-2xl font-semibold text-slate-900 flex items-center gap-3">
      <span class="font-mono"><%= @order.number %></span>
      <%= render "status_badge", status: @order.status %>
    </h1>
    <p class="text-sm text-slate-500 mt-1">
      Placed <%= l(@order.created_at, format: :long) %>
      <% if @order.last_tracking_synced_at %>
        · Last tracking sync <%= time_ago_in_words(@order.last_tracking_synced_at) %> ago
      <% end %>
    </p>
  </div>

  <div class="flex flex-wrap gap-2">
    <% @order.available_events.each do |event| %>
      <%= button_to event.to_s.titleize,
            transition_order_path(@order),
            method: :post,
            params: { event: event },
            data: { turbo_confirm: "#{event.to_s.titleize} order #{@order.number}?" },
            class: action_button_classes(event) %>
    <% end %>

    <% if @order.shipped? || @order.delivered? %>
      <%= button_to "Sync tracking",
            sync_tracking_order_path(@order),
            method: :post,
            class: "rounded-md border border-slate-300 bg-white px-3 py-1.5 text-sm font-medium text-slate-700 hover:bg-slate-50" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <section class="lg:col-span-2 space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg shadow-sm">
      <header class="px-4 py-3 border-b border-slate-200 flex items-center justify-between">
        <h2 class="font-medium text-slate-900">Line items</h2>
        <span class="text-sm text-slate-500"><%= pluralize(@line_items.size, "item") %></span>
      </header>
      <table class="w-full text-sm">
        <thead class="text-left text-xs uppercase tracking-wide text-slate-500 border-b border-slate-200">
          <tr>
            <th class="px-4 py-2">Product</th>
            <th class="px-4 py-2">SKU</th>
            <th class="px-4 py-2 text-right">Qty</th>
            <th class="px-4 py-2 text-right">Unit price</th>
            <th class="px-4 py-2 text-right">Subtotal</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200">
          <% @line_items.each do |item| %>
            <tr>
              <td class="px-4 py-3 text-slate-900"><%= item.product.name %></td>
              <td class="px-4 py-3 font-mono text-xs text-slate-500"><%= item.product.sku %></td>
              <td class="px-4 py-3 text-right tabular-nums"><%= item.quantity %></td>
              <td class="px-4 py-3 text-right tabular-nums">$<%= number_with_precision(item.unit_price, precision: 2) %></td>
              <td class="px-4 py-3 text-right tabular-nums font-medium">$<%= number_with_precision(item.subtotal, precision: 2) %></td>
            </tr>
          <% end %>
        </tbody>
        <tfoot class="bg-slate-50 border-t border-slate-200">
          <tr>
            <td class="px-4 py-3 font-medium" colspan="4">Total</td>
            <td class="px-4 py-3 text-right font-semibold tabular-nums">$<%= number_with_precision(@order.total, precision: 2) %></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <%= turbo_stream_from @order %>
    <%= render "tracking_timeline", order: @order %>
  </section>

  <aside class="space-y-6">
    <div class="bg-white border border-slate-200 rounded-lg shadow-sm p-4">
      <h2 class="font-medium text-slate-900 mb-3">Customer</h2>
      <dl class="text-sm space-y-2">
        <div>
          <dt class="text-slate-500 text-xs uppercase tracking-wide">Name</dt>
          <dd class="text-slate-900"><%= @order.customer_name %></dd>
        </div>
        <div>
          <dt class="text-slate-500 text-xs uppercase tracking-wide">Email</dt>
          <dd class="text-slate-900"><%= @order.customer_email %></dd>
        </div>
        <div>
          <dt class="text-slate-500 text-xs uppercase tracking-wide">Shipping address</dt>
          <dd class="text-slate-900 whitespace-pre-line"><%= @order.shipping_address %></dd>
        </div>
        <% if @order.tracking_number.present? %>
          <div>
            <dt class="text-slate-500 text-xs uppercase tracking-wide">Carrier / tracking</dt>
            <dd class="text-slate-900"><%= @order.carrier %> · <span class="font-mono"><%= @order.tracking_number %></span></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="bg-white border border-slate-200 rounded-lg shadow-sm p-4">
      <h2 class="font-medium text-slate-900 mb-3">Audit history</h2>
      <% if @audit_history.any? %>
        <ol class="space-y-3 text-sm">
          <% @audit_history.each do |entry| %>
            <li class="flex gap-3">
              <span class="mt-1 inline-block h-2 w-2 rounded-full bg-slate-400"></span>
              <div>
                <div class="text-slate-900">
                  <%= entry.event.titleize %>
                  <% if entry.changes["status"] %>
                    · status <span class="font-mono text-xs"><%= entry.changes["status"].first %></span>
                    →
                    <span class="font-mono text-xs"><%= entry.changes["status"].last %></span>
                  <% end %>
                </div>
                <div class="text-slate-500 text-xs">
                  <%= l(entry.at, format: :short) %> · by <%= entry.actor_label %>
                </div>
              </div>
            </li>
          <% end %>
        </ol>
      <% else %>
        <p class="text-sm text-slate-500">No history yet.</p>
      <% end %>
    </div>
  </aside>
</div>
