<div id="<%= dom_id(order, :tracking) %>" class="bg-white border border-slate-200 rounded-lg shadow-sm">
  <header class="px-4 py-3 border-b border-slate-200">
    <h2 class="font-medium text-slate-900">Carrier tracking</h2>
  </header>

  <% events = order.tracking_events.chronological.to_a %>
  <% if events.any? %>
    <ol class="px-4 py-4 space-y-4">
      <% events.each_with_index do |event, idx| %>
        <li class="flex gap-3">
          <div class="flex flex-col items-center">
            <span class="h-2.5 w-2.5 rounded-full <%= idx == events.length - 1 ? "bg-emerald-500" : "bg-slate-300" %>"></span>
            <% unless idx == events.length - 1 %><span class="w-px flex-1 bg-slate-200"></span><% end %>
          </div>
          <div class="pb-2">
            <div class="text-sm font-medium text-slate-900"><%= event.description.presence || event.status.titleize %></div>
            <div class="text-xs text-slate-500">
              <%= l(event.occurred_at, format: :short) %>
              <% if event.location.present? %>· <%= event.location %><% end %>
            </div>
          </div>
        </li>
      <% end %>
    </ol>
  <% else %>
    <p class="px-4 py-6 text-sm text-slate-500">
      <% if order.shipped? || order.delivered? %>
        Tracking sync hasn't completed yet — events will appear here automatically.
      <% else %>
        Tracking events will appear once the order ships.
      <% end %>
    </p>
  <% end %>
</div>
